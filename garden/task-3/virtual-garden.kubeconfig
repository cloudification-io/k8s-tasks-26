apiVersion: v1
kind: Config
clusters:
- name: virtual-garden
  cluster:
    server: https://127.0.0.1:6443
    certificate-authority-data: 
users:
- name: garden-admin
  user:
    client-certificate-data: 
    client-key-data: 
contexts:
- name: virtual-garden
  context:
    cluster: virtual-garden
    user: garden-admin
current-context: virtual-garden
